# Kopier til .env og fyll inn verdier
# cp .env.example .env

# Database
DB_USER=summa
DB_PASSWORD=BYTT_DETTE_TIL_SIKKERT_PASSORD
DB_NAME=summa

# JWT (generer med: openssl rand -base64 48)
JWT_SECRET=BYTT_DETTE_TIL_TILFELDIG_STRENG_MINST_32_TEGN

# CORS - Tillatte domener (kommaseparert, uten https://)
ALLOWED_ORIGINS=summa.tommytv.no

# E-post (utgående via lokal Postfix)
SMTP_FROM=noreply@summa.tommytv.no

# App-domene (for lenker i e-poster)
APP_DOMAIN=summa.tommytv.no

# E-post auth (false for lokal Postfix, true for ekstern SMTP)
SMTP_AUTH_REQUIRED=false

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# Anthropic API (for automatisk parsing av kvitteringer/fakturaer)
# Opprett nøkkel på console.anthropic.com
ANTHROPIC_API_KEY=

# Initial admin-bruker (påkrevd for første produksjonsstart)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_NAME=
